<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --eu-blue:#003399;--eu-yellow:#FFCC00;--eu-blue-mid:#336699;
  --eu-blue-light:#E8EEF8;--eu-blue-pale:#F0F4FA;--text:#1C1C1C;
  --muted:#5C6470;--border:#D4D8DF;--bg:#FFFFFF;--surface:#F5F7FA;
  --radius:6px;--accent:#003399;
  --ds-purple:#7C3AED;--ds-purple-light:#EDE9FE;--ds-purple-pale:#F5F3FF;
  --compte-green:#059669;--compte-green-light:#D1FAE5;--compte-green-pale:#ECFDF5;
  --shadow:0 4px 16px rgba(0,0,0,0.08);--shadow-hover:0 8px 32px rgba(0,0,0,0.12);
  --transition:0.25s cubic-bezier(0.4,0,0.2,1);
}
html{scroll-behavior:smooth}
body{font-family:'Source Sans 3',sans-serif;color:var(--text);background:var(--surface);font-size:14px;line-height:1.55;overflow-x:hidden}

/* ── DARK MODE ── */
body.dark-mode{--text:#F1F5F9;--muted:#94A3B8;--bg:#0F172A;--surface:#1E293B;--surface-alt:#334155;--border:#334155;--eu-blue-light:#1E3A5F;--eu-blue-pale:#1E293B;--shadow:0 4px 16px rgba(0,0,0,0.3);--shadow-hover:0 8px 32px rgba(0,0,0,0.4);--ds-purple-light:#4C1D95;--ds-purple-pale:#1E1B4B;--compte-green-light:#064E3B;--compte-green-pale:#064E3B}
body.dark-mode .card,body.dark-mode .hero,body.dark-mode .bpmn-pool{background:var(--surface);border-color:#334155}
body.dark-mode .legend-card{background:#1E293B;border-color:#475569}
body.dark-mode .bpmn-lane{background:#1E293B}
body.dark-mode .bpmn-task{background:#334155;border-color:#475569;color:#F1F5F9}
body.dark-mode .bpmn-event-start{background:#1E293B;border-color:#475569}
body.dark-mode .bpmn-event-end{background:#1E293B;border-color:#EF4444}
body.dark-mode .bpmn-gateway{background:#1E293B;border-color:#475569}
body.dark-mode .bpmn-flow-line{background:#475569}
body.dark-mode .bpmn-annotation{background:#1E293B;border-color:#475569;color:#94A3B8}

/* ── TOPBAR ── */
.topbar{background:var(--eu-blue);color:white;display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:52px;position:fixed;top:0;left:0;right:0;z-index:200;gap:1rem}
.topbar-left{display:flex;align-items:center;gap:16px}
.eu-logo{display:flex;align-items:center;gap:8px;text-decoration:none}
.eu-stars{font-size:10px;letter-spacing:1px;color:var(--eu-yellow)}
.eu-wordmark{font-size:11px;font-weight:700;color:white;letter-spacing:0.08em;text-transform:uppercase}
.topbar-name{font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);border-left:1px solid rgba(255,255,255,0.25);padding-left:16px}
.topbar-right{display:flex;align-items:center;gap:8px}
.back-btn{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:rgba(255,255,255,0.8);background:transparent;border:1px solid rgba(255,255,255,0.3);border-radius:3px;padding:3px 10px;cursor:pointer;font-family:'Source Sans 3',sans-serif;text-decoration:none;transition:all var(--transition)}
.back-btn:hover{border-color:var(--eu-yellow);color:var(--eu-yellow)}
.icon-btn{width:32px;height:32px;border-radius:50%;border:1px solid rgba(255,255,255,0.3);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all var(--transition);color:rgba(255,255,255,0.8);margin-left:4px}
.icon-btn:hover{background:rgba(255,204,0,0.15);border-color:var(--eu-yellow);color:var(--eu-yellow)}
.icon-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}

.page{max-width:1200px;margin:0 auto;padding:72px 1.5rem 4rem}

/* ── HERO ── */
.hero{background:var(--bg);border:1px solid var(--border);border-top:4px solid var(--eu-blue);padding:2rem;margin-bottom:1.5rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--eu-blue),var(--eu-yellow));opacity:0;transition:opacity var(--transition)}
.hero:hover::before{opacity:1}
.hero h1{font-family:'Source Serif 4',serif;font-size:32px;font-weight:700;color:var(--eu-blue);margin-bottom:8px}
.hero-subtitle{font-size:14px;color:var(--muted);max-width:600px;margin:0 auto 16px}
.hero-badges{display:flex;justify-content:center;gap:10px;flex-wrap:wrap}
.hero-badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:5px 14px;border-radius:100px;border:2px solid transparent;transition:all var(--transition)}
.hero-badge.ds{background:var(--ds-purple-light);color:var(--ds-purple);border-color:var(--ds-purple-light)}
.hero-badge.ds:hover{background:var(--ds-purple);color:white}
.hero-badge.compte{background:var(--compte-green-light);color:var(--compte-green);border-color:var(--compte-green-light)}
.hero-badge.compte:hover{background:var(--compte-green);color:white}
.hero-badge.eu{background:var(--eu-blue-light);color:var(--eu-blue);border-color:var(--eu-blue-light)}
.hero-badge.eu:hover{background:var(--eu-blue);color:white}

/* ── SECTIONS ── */
.section{margin-bottom:2rem}
.section-header{display:flex;align-items:center;gap:12px;margin-bottom:1rem}
.section-title{font-family:'Source Serif 4',serif;font-size:20px;font-weight:700;color:var(--text)}
.section-line{flex:1;height:2px;background:linear-gradient(90deg,var(--eu-blue),transparent);border-radius:1px}

/* ── BPMN DIAGRAM ── */
.bpmn-container{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;overflow-x:auto;margin-bottom:1.5rem;position:relative}
.bpmn-container:hover{box-shadow:var(--shadow)}
.bpmn-pool{border:2px solid var(--eu-blue);border-radius:var(--radius);min-width:900px;position:relative;background:var(--bg)}
.bpmn-pool-header{background:var(--eu-blue);color:white;padding:8px 16px;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;display:flex;align-items:center;gap:8px}
.bpmn-pool-header svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.bpmn-lanes{display:flex;flex-direction:column}
.bpmn-lane{border-bottom:1px dashed var(--border);padding:16px;position:relative;min-height:120px}
.bpmn-lane:last-child{border-bottom:none}
.bpmn-lane-header{position:absolute;left:0;top:0;bottom:0;width:40px;background:var(--eu-blue-light);display:flex;align-items:center;justify-content:center;writing-mode:vertical-rl;text-orientation:mixed;font-size:10px;font-weight:700;color:var(--eu-blue);letter-spacing:0.1em;text-transform:uppercase;border-right:1px solid var(--border)}
.bpmn-lane-content{margin-left:48px;position:relative;min-height:80px}

/* ── BPMN ELEMENTS ── */
.bpmn-element{position:absolute;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;text-align:center;cursor:pointer;transition:all var(--transition);z-index:2}
.bpmn-element:hover{transform:scale(1.08);z-index:10}
.bpmn-element:hover .bpmn-tooltip{opacity:1;visibility:visible;transform:translateY(0)}

/* Start Event */
.bpmn-event-start{width:36px;height:36px;border-radius:50%;border:3px solid var(--compte-green);background:white;display:flex;align-items:center;justify-content:center}
.bpmn-event-start::after{content:'';width:8px;height:8px;border-radius:50%;background:var(--compte-green)}

/* End Event */
.bpmn-event-end{width:36px;height:36px;border-radius:50%;border:3px solid #EF4444;background:white;display:flex;align-items:center;justify-content:center}
.bpmn-event-end::after{content:'';width:16px;height:16px;border-radius:50%;background:#EF4444}

/* Task */
.bpmn-task{width:140px;height:50px;border-radius:var(--radius);border:2px solid var(--eu-blue);background:var(--eu-blue-pale);color:var(--eu-blue);display:flex;align-items:center;justify-content:center;padding:4px 8px;line-height:1.3}
.bpmn-task.ds{border-color:var(--ds-purple);background:var(--ds-purple-pale);color:var(--ds-purple)}
.bpmn-task.compte{border-color:var(--compte-green);background:var(--compte-green-pale);color:var(--compte-green)}
.bpmn-task:hover{box-shadow:var(--shadow);transform:translateY(-2px)}

/* Gateway */
.bpmn-gateway{width:40px;height:40px;background:white;border:2px solid var(--eu-blue);transform:rotate(45deg);display:flex;align-items:center;justify-content:center}
.bpmn-gateway span{transform:rotate(-45deg);font-size:16px;font-weight:700;color:var(--eu-blue)}
.bpmn-gateway:hover{box-shadow:var(--shadow)}

/* Sub-process */
.bpmn-subprocess{width:160px;height:60px;border-radius:var(--radius);border:2px solid var(--eu-blue);background:var(--eu-blue-pale);display:flex;align-items:center;justify-content:center;position:relative}
.bpmn-subprocess::before{content:'';position:absolute;top:4px;left:4px;right:4px;bottom:4px;border:1px dashed var(--eu-blue);border-radius:3px;opacity:0.3}
.bpmn-subprocess.ds{border-color:var(--ds-purple);background:var(--ds-purple-pale)}
.bpmn-subprocess.ds::before{border-color:var(--ds-purple)}
.bpmn-subprocess.compte{border-color:var(--compte-green);background:var(--compte-green-pale)}
.bpmn-subprocess.compte::before{border-color:var(--compte-green)}

/* Data Object */
.bpmn-data{width:30px;height:40px;border:2px solid var(--eu-blue);background:white;border-radius:3px 3px 0 0;position:relative;transform:skewX(-10deg)}
.bpmn-data::after{content:'';position:absolute;bottom:-6px;left:4px;right:4px;height:6px;border:2px solid var(--eu-blue);border-top:none;border-radius:0 0 3px 3px;background:white}

/* Annotation */
.bpmn-annotation{background:#FEF3C7;border:1px solid #FCD34D;border-radius:3px;padding:6px 10px;font-size:10px;color:#92400E;max-width:180px;line-height:1.4;position:absolute}
.bpmn-annotation::before{content:'';position:absolute;left:-8px;top:50%;transform:translateY(-50%);width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-right:8px solid #FCD34D}

/* Flow Lines */
.bpmn-flow-line{position:absolute;height:2px;background:var(--border);z-index:1;transition:all var(--transition)}
.bpmn-flow-line:hover{background:var(--eu-blue)}
.bpmn-flow-arrow{position:absolute;width:0;height:0;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:6px solid var(--border);right:-6px;top:50%;transform:translateY(-50%)}
.bpmn-flow-line:hover .bpmn-flow-arrow{border-left-color:var(--eu-blue)}
.bpmn-flow-dashed{background:repeating-linear-gradient(90deg,var(--border),var(--border) 6px,transparent 6px,transparent 12px)}
.bpmn-flow-dashed .bpmn-flow-arrow{border-left-color:var(--border)}

/* Tooltip */
.bpmn-tooltip{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%) translateY(4px);background:var(--text);color:white;padding:8px 12px;border-radius:var(--radius);font-size:11px;white-space:nowrap;opacity:0;visibility:hidden;transition:all var(--transition);z-index:100;box-shadow:var(--shadow-hover);pointer-events:none}
.bpmn-tooltip::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--text)}

/* ── LEGENDS ── */
.legends-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:1.5rem;margin-bottom:2rem}
.legend-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;transition:all var(--transition)}
.legend-card:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.legend-card.ds{border-top:4px solid var(--ds-purple)}
.legend-card.compte{border-top:4px solid var(--compte-green)}
.legend-card.eu{border-top:4px solid var(--eu-blue)}
.legend-title{font-family:'Source Serif 4',serif;font-size:16px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.legend-title.ds{color:var(--ds-purple)}
.legend-title.compte{color:var(--compte-green)}
.legend-title.eu{color:var(--eu-blue)}
.legend-table{width:100%;border-collapse:collapse;font-size:12px}
.legend-table th{text-align:left;padding:6px 8px;background:var(--surface);font-weight:700;color:var(--muted);font-size:10px;letter-spacing:0.05em;text-transform:uppercase;border-bottom:2px solid var(--border)}
.legend-table td{padding:8px;border-bottom:1px solid var(--border);vertical-align:top}
.legend-table tr:hover td{background:var(--surface)}
.legend-symbol{width:32px;height:32px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.legend-symbol svg{width:20px;height:20px}
.legend-desc{font-size:11px;color:var(--muted);line-height:1.4}
.legend-example{font-size:10px;color:var(--eu-blue);font-style:italic;margin-top:2px}

/* ── TIMELINE MINI ── */
.mini-timeline{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;overflow-x:auto;padding:8px 0}
.mini-step{flex:1;min-width:100px;text-align:center;position:relative;padding-top:20px}
.mini-step::before{content:'';position:absolute;top:6px;left:50%;width:12px;height:12px;border-radius:50%;background:var(--border);border:2px solid var(--border);transform:translateX(-50%);transition:all var(--transition)}
.mini-step.active::before{background:var(--eu-blue);border-color:var(--eu-blue)}
.mini-step.ds::before{background:var(--ds-purple);border-color:var(--ds-purple)}
.mini-step.compte::before{background:var(--compte-green);border-color:var(--compte-green)}
.mini-step::after{content:'';position:absolute;top:11px;left:calc(50% + 8px);right:calc(-50% + 8px);height:2px;background:var(--border);z-index:-1}
.mini-step:last-child::after{display:none}
.mini-year{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px}
.mini-label{font-size:11px;font-weight:600;color:var(--text);line-height:1.3}
.mini-step:hover .mini-year{color:var(--eu-blue)}
.mini-step:hover::before{transform:translateX(-50%) scale(1.3)}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .bpmn-container{overflow-x:scroll}
  .legends-grid{grid-template-columns:1fr}
  .topbar{flex-wrap:wrap;height:auto;padding:8px 1rem}
  .topbar-name{display:none}
}
@media print{
  .topbar,.icon-btn{display:none!important}
  body{background:white}
  .bpmn-container{overflow:visible}
  .bpmn-pool{min-width:auto}
}
</style>
</head>
