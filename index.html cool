<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Stevenson Laurent — CV Europass</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&family=Source+Serif+4:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --eu-blue:#003399;--eu-yellow:#FFCC00;--eu-blue-mid:#336699;
  --eu-blue-light:#E8EEF8;--eu-blue-pale:#F0F4FA;--text:#1C1C1C;
  --muted:#5C6470;--border:#D4D8DF;--bg:#FFFFFF;--surface:#F5F7FA;
  --radius:4px;--accent:#003399;
  --flexi-green:#2D7D46;--flexi-green-bg:#E8F5ED;--flexi-green-border:#B3DEC3;
}
html{scroll-behavior:smooth}
body{font-family:'Source Sans 3',sans-serif;color:var(--text);background:var(--surface);font-size:14px;line-height:1.55}

/* ── LIEN DE RÉFÉRENCE ── */
a.ref-link{
  color:var(--eu-blue);text-decoration:none;border-bottom:1px dotted var(--eu-blue-mid);
  transition:color 0.15s,border-color 0.15s;display:inline-flex;align-items:center;gap:3px;
}
a.ref-link:hover{color:var(--eu-blue-mid);border-bottom-style:solid}
a.ref-link .ext-icon{width:10px;height:10px;flex-shrink:0;opacity:0.6;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
a.ref-link:hover .ext-icon{opacity:1}

.topbar{background:var(--eu-blue);color:white;display:flex;align-items:center;justify-content:space-between;padding:0 2rem;height:48px;position:sticky;top:0;z-index:200;gap:1rem;}
.topbar-left{display:flex;align-items:center;gap:16px}
.eu-logo{display:flex;align-items:center;gap:8px;text-decoration:none}
.eu-stars{font-size:10px;letter-spacing:1px;color:var(--eu-yellow)}
.eu-wordmark{font-size:11px;font-weight:700;color:white;letter-spacing:0.08em;text-transform:uppercase}
.topbar-name{font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);border-left:1px solid rgba(255,255,255,0.25);padding-left:16px}
.topbar-right{display:flex;align-items:center;gap:8px}
.lang-switch{display:flex;gap:4px}
.lang-btn{font-size:11px;font-weight:700;color:rgba(255,255,255,0.6);background:transparent;border:1px solid rgba(255,255,255,0.25);border-radius:3px;padding:3px 8px;cursor:pointer;letter-spacing:0.05em;transition:all 0.2s;font-family:'Source Sans 3',sans-serif;}
.lang-btn:hover,.lang-btn.active{color:var(--eu-yellow);border-color:var(--eu-yellow);background:rgba(255,204,0,0.1)}
.profile-switch{display:flex;gap:4px}
.profile-btn{font-size:11px;font-weight:600;color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:3px;padding:3px 10px;cursor:pointer;transition:all 0.2s;font-family:'Source Sans 3',sans-serif;white-space:nowrap;}
.profile-btn:hover,.profile-btn.active{background:rgba(255,204,0,0.15);border-color:var(--eu-yellow);color:white}
.print-btn-top{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:rgba(255,255,255,0.8);background:transparent;border:1px solid rgba(255,255,255,0.3);border-radius:3px;padding:3px 10px;cursor:pointer;font-family:'Source Sans 3',sans-serif;transition:all 0.2s;}
.print-btn-top:hover{border-color:var(--eu-yellow);color:var(--eu-yellow)}
.europass-band{background:var(--eu-blue);padding:1.5rem 2rem;display:flex;align-items:center;gap:16px;}
.ep-flag{width:42px;height:28px;background:var(--eu-blue);border:1.5px solid rgba(255,255,255,0.3);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:8px;letter-spacing:1px;color:var(--eu-yellow);flex-shrink:0;}
.ep-tag{font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.7);font-weight:600}
.ep-subtitle{font-size:11px;color:rgba(255,255,255,0.5);margin-top:1px}
.page{max-width:980px;margin:0 auto;padding:0 1.5rem 4rem}
.hero{background:var(--bg);border:1px solid var(--border);border-top:4px solid var(--eu-blue);padding:2rem 2rem 1.75rem;display:grid;grid-template-columns:auto 1fr;gap:2rem;align-items:flex-start;margin-bottom:1.25rem;}
.avatar{width:96px;height:96px;border-radius:50%;background:var(--eu-blue);overflow:hidden;flex-shrink:0;border:2px solid var(--border);}
.avatar img{width:100%;height:100%;object-fit:cover}
.avatar-fallback{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Source Serif 4',serif;font-size:28px;color:var(--eu-yellow);}
.hero-name{font-family:'Source Serif 4',serif;font-size:28px;font-weight:700;color:var(--eu-blue);letter-spacing:-0.01em;line-height:1.1}
.hero-title{font-size:12px;font-weight:600;color:var(--muted);margin:6px 0 4px;letter-spacing:0.1em;text-transform:uppercase}
.profile-title{font-size:15px;font-weight:600;color:var(--text);margin-bottom:10px}
.hero-bio{font-size:13.5px;color:var(--muted);line-height:1.65;max-width:560px;margin-bottom:16px}
.contact-bar{display:flex;flex-wrap:wrap;gap:8px}
.contact-chip{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--muted);background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:3px 10px;text-decoration:none;transition:border-color 0.2s,color 0.2s;}
.contact-chip:hover{border-color:var(--eu-blue);color:var(--eu-blue)}
.contact-chip svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.main-grid{display:grid;grid-template-columns:1fr 300px;gap:1.25rem;align-items:start}
.card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;margin-bottom:1.25rem}
.card:last-child{margin-bottom:0}
.section-label{font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--eu-blue);margin-bottom:1rem;padding-bottom:7px;border-bottom:2px solid var(--eu-blue-light);display:flex;align-items:center;gap:8px;}
.section-label .sl-icon{width:16px;height:16px;background:var(--eu-blue);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;}
.section-label .sl-icon svg{width:10px;height:10px;stroke:white;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.job{margin-bottom:1.25rem;padding-bottom:1.25rem;border-bottom:1px solid var(--border)}
.job:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.job-row{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:4px}
.job-company{font-size:13.5px;font-weight:700;color:var(--text)}
.job-date{font-size:11px;color:var(--eu-blue);background:var(--eu-blue-light);padding:2px 8px;border-radius:3px;font-weight:600;white-space:nowrap}
.job-role{font-size:12px;color:var(--muted);margin:2px 0 7px;font-style:italic}
.job-location{font-size:11px;color:var(--muted);margin-bottom:6px}
.bullets{list-style:none;padding:0}
.bullets li{font-size:12.5px;color:var(--muted);line-height:1.55;padding:2px 0 2px 14px;position:relative}
.bullets li::before{content:'▸';position:absolute;left:0;color:var(--eu-blue);font-size:10px;top:3px}
.edu-item{margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--border)}
.edu-item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.edu-school{font-size:13px;font-weight:700}
.edu-degree{font-size:12.5px;color:var(--muted);margin:2px 0}
.edu-date{font-size:11px;color:var(--eu-blue);font-weight:600}
.edu-note{font-size:11px;color:var(--muted);margin-top:2px}
.skill-group{margin-bottom:1rem}
.skill-group-title{font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--eu-blue);margin-bottom:6px}
.skill-tags{display:flex;flex-wrap:wrap;gap:5px}
.skill-tag{font-size:11.5px;background:var(--eu-blue-pale);color:var(--eu-blue);border:1px solid var(--eu-blue-light);border-radius:3px;padding:2px 8px}
.lang-item{margin-bottom:10px}
.lang-item:last-child{margin-bottom:0}
.lang-row{display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:4px}
.lang-name{font-weight:700}
.lang-level{color:var(--muted);font-size:11.5px}
.lang-dots{display:flex;gap:4px}
.lang-dot{width:10px;height:10px;border-radius:50%;background:var(--border)}
.lang-dot.filled{background:var(--eu-blue)}
.cefr{font-size:10px;color:var(--muted);margin-top:2px}
.cont-item{font-size:12px;color:var(--muted);padding:6px 0;border-bottom:1px solid var(--border);line-height:1.4}
.cont-item:last-child{border-bottom:none}
.cont-year{font-size:10px;color:var(--eu-blue);font-weight:700;display:block;margin-bottom:1px;letter-spacing:0.05em;text-transform:uppercase}
.cert-item{display:flex;justify-content:space-between;align-items:flex-start;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px}
.cert-item:last-child{border-bottom:none}
.cert-name{font-weight:600;color:var(--text)}
.cert-year{font-size:11px;color:var(--eu-blue);font-weight:700;flex-shrink:0}
.status-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:#2D7D46;background:#E8F5ED;border:1px solid #B3DEC3;border-radius:3px;padding:3px 10px;margin-bottom:12px;}
.status-dot{width:7px;height:7px;border-radius:50%;background:#2D7D46}

/* ── FLEXI-JOB STYLES ── */
.flexi-card{
  background:var(--bg);border:1px solid var(--flexi-green-border);
  border-top:4px solid var(--flexi-green);
  border-radius:var(--radius);padding:1.5rem;margin-bottom:1.25rem;
}
.flexi-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.flexi-badge-eligible{
  display:inline-flex;align-items:center;gap:6px;
  font-size:11px;font-weight:700;color:var(--flexi-green);
  background:var(--flexi-green-bg);border:1px solid var(--flexi-green-border);
  border-radius:3px;padding:4px 12px;
}
.flexi-dot{width:8px;height:8px;border-radius:50%;background:var(--flexi-green);flex-shrink:0}
.flexi-section-label{
  font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--flexi-green);margin-bottom:1rem;padding-bottom:7px;
  border-bottom:2px solid var(--flexi-green-bg);
  display:flex;align-items:center;gap:8px;
}
.flexi-section-label .sl-icon{width:16px;height:16px;background:var(--flexi-green);border-radius:2px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;}
.flexi-section-label .sl-icon svg{width:10px;height:10px;stroke:white;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.flexi-info{font-size:12px;color:var(--muted);margin-bottom:14px;line-height:1.6;background:var(--flexi-green-bg);border-radius:3px;padding:10px 12px;border-left:3px solid var(--flexi-green);}
.flexi-info strong{color:var(--flexi-green);font-weight:700}
.flexi-roles{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.flexi-role{display:flex;align-items:flex-start;gap:8px;padding:8px 10px;border:1px solid var(--flexi-green-border);border-radius:3px;background:#F7FCF9;}
.flexi-role-icon{font-size:18px;flex-shrink:0;margin-top:1px}
.flexi-role-text{}
.flexi-role-name{font-size:12px;font-weight:700;color:var(--text)}
.flexi-role-desc{font-size:11px;color:var(--muted);margin-top:1px}
.flexi-period{font-size:11px;color:var(--muted);margin-top:10px;text-align:right;font-style:italic}
.flexi-avantages{margin-top:10px}
.flexi-avantage-tag{display:inline-flex;align-items:center;gap:4px;font-size:11px;background:var(--flexi-green-bg);color:var(--flexi-green);border:1px solid var(--flexi-green-border);border-radius:3px;padding:2px 8px;margin:2px 3px 2px 0}

[data-profile]{display:none}
[data-profile].active{display:block}
.bio-text{display:none}
.bio-text.active{display:block}

footer{text-align:center;padding:2rem 0 0;font-size:11px;color:#bbb}
footer .ep-footer{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:4px}
footer .ep-footer-stars{font-size:9px;color:var(--eu-yellow)}

@media print{
  .topbar,.print-btn-top,.lang-switch,.profile-switch{display:none!important}
  body{background:white}
  .card,.hero,.flexi-card{border:1px solid #ccc}
  .page{padding:0}
  a.ref-link{color:var(--eu-blue);border-bottom:none}
}
@media(max-width:720px){
  .hero{grid-template-columns:1fr;text-align:center}
  .avatar{margin:0 auto}
  .contact-bar{justify-content:center}
  .main-grid{grid-template-columns:1fr}
  .topbar{flex-wrap:wrap;height:auto;padding:8px 1rem;gap:8px}
  .topbar-name{display:none}
  .profile-btn{font-size:10px;padding:2px 7px}
  .lang-btn{font-size:10px;padding:2px 6px}
  .flexi-roles{grid-template-columns:1fr}
}
</style>
</head>
<body>

