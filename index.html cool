<div class="europass-band">
  <div class="ep-flag">★★★<br>★★★<br>★★★</div>
  <div>
    <div class="ep-tag">Curriculum Vitæ</div>
    <div class="ep-subtitle t" data-fr="Format Europass — Union Européenne" data-en="Europass Format — European Union" data-nl="Europass Formaat — Europese Unie">Format Europass — Union Européenne</div>
