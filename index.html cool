<script>
let currentLang='fr',currentProfile='comptable';
function setLang(lang){
  currentLang=lang;
  document.documentElement.lang=lang;
  document.querySelectorAll('.t').forEach(el=>{const v=el.getAttribute('data-'+lang);if(v)el.innerHTML=v;});
  document.querySelectorAll('.lang-btn').forEach(btn=>{btn.classList.toggle('active',btn.textContent.trim().toLowerCase()===lang);});
}
function setProfile(profile){
  currentProfile=profile;
  document.querySelectorAll('.bio-text').forEach(el=>el.classList.remove('active'));
  document.getElementById('bio-'+profile).classList.add('active');
  document.querySelectorAll('.profile-btn').forEach(btn=>btn.classList.remove('active'));
  document.getElementById('pb-'+profile).classList.add('active');
}
setLang('fr');
</script>
